{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "k6 load and concurrency test results — dual remote-write (Prometheus + VictoriaMetrics)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "none",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Active VUs",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "k6_vus", "legendFormat": "VUs", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.01 } ] }, "unit": "percentunit", "mappings": [] },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_http_req_failed_total[1m])", "legendFormat": "error rate", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 800 } ] }, "unit": "reqps", "mappings": [] },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Request Rate",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_http_reqs_total[1m])", "legendFormat": "req/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "red", "value": 30 } ] }, "unit": "ms", "mappings": [] },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "p99 Latency (overall)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket[1m])) by (le)) * 1000", "legendFormat": "p99", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 25 } ] }, "unit": "ms", "mappings": [] },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "p95 Latency (overall)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket[1m])) by (le)) * 1000", "legendFormat": "p95", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "unit": "none", "mappings": [] },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Iterations",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(k6_iterations_total[10m]))", "legendFormat": "iterations", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Virtual Users & Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "none" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "VUs" }, "properties": [ { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["max", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Virtual Users over time",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "k6_vus", "legendFormat": "VUs", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "k6_vus_max", "legendFormat": "VUs max", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Request Rate & Iteration Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_http_reqs_total[30s])", "legendFormat": "HTTP req/s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_iterations_total[30s])", "legendFormat": "iterations/s", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "HTTP Latency — Percentiles",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "p90" }, "properties": [ { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "thresholds": {
          "mode": "line",
          "steps": [
            { "color": "transparent", "value": null },
            { "color": "orange", "value": 15 },
            { "color": "red", "value": 30 }
          ]
        }
      },
      "title": "HTTP Request Duration — p50 / p90 / p95 / p99",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_bucket[30s])) by (le)) * 1000", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum(rate(k6_http_req_duration_bucket[30s])) by (le)) * 1000", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket[30s])) by (le)) * 1000", "legendFormat": "p95", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket[30s])) by (le)) * 1000", "legendFormat": "p99", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "HTTP Duration Breakdown (connecting / waiting / receiving)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_connecting_bucket[30s])) by (le)) * 1000", "legendFormat": "p95 connecting", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_waiting_bucket[30s])) by (le)) * 1000", "legendFormat": "p95 waiting (TTFB)", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_receiving_bucket[30s])) by (le)) * 1000", "legendFormat": "p95 receiving", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_sending_bucket[30s])) by (le)) * 1000", "legendFormat": "p95 sending", "refId": "D" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "title": "Per-Scenario Thresholds (warm_up / hot_account_burst / mixed_load)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "id": 30,
      "options": {
        "legend": { "calcs": ["max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "thresholds": { "mode": "line", "steps": [ { "color": "transparent", "value": null }, { "color": "red", "value": 8 } ] }
      },
      "title": "warm_up — p99 (threshold: < 8 ms)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket{scenario=\"warm_up\"}[30s])) by (le)) * 1000", "legendFormat": "p99 warm_up", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket{scenario=\"warm_up\"}[30s])) by (le)) * 1000", "legendFormat": "p95 warm_up", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "id": 31,
      "options": {
        "legend": { "calcs": ["max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "thresholds": { "mode": "line", "steps": [ { "color": "transparent", "value": null }, { "color": "orange", "value": 15 }, { "color": "red", "value": 30 } ] }
      },
      "title": "hot_account_burst — p95 (< 15 ms) / p99 (< 30 ms)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket{scenario=\"hot_account_burst\"}[30s])) by (le)) * 1000", "legendFormat": "p95 hot_burst", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket{scenario=\"hot_account_burst\"}[30s])) by (le)) * 1000", "legendFormat": "p99 hot_burst", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "id": 32,
      "options": {
        "legend": { "calcs": ["max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "thresholds": { "mode": "line", "steps": [ { "color": "transparent", "value": null }, { "color": "orange", "value": 12 }, { "color": "red", "value": 25 } ] }
      },
      "title": "mixed_load — p95 (< 12 ms) / p99 (< 25 ms)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket{scenario=\"mixed_load\"}[30s])) by (le)) * 1000", "legendFormat": "p95 mixed", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket{scenario=\"mixed_load\"}[30s])) by (le)) * 1000", "legendFormat": "p99 mixed", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104,
      "title": "Errors & Status Codes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 20 }, "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx / s" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "503 / s" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "202 / s" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 40,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Requests by HTTP Status",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_http_reqs_total{status=\"202\"}[30s])", "legendFormat": "202 / s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_http_reqs_total{status=\"400\"}[30s])", "legendFormat": "400 / s", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_http_reqs_total{status=\"503\"}[30s])", "legendFormat": "503 (OVERLOADED) / s", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_http_reqs_total{status=~\"5..\"}[30s])", "legendFormat": "5xx / s", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percentunit" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error rate" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "503 rate" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 41,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Error Rate % (burst threshold: 503 rate < 5%)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(k6_http_req_failed_total[30s]) / rate(k6_http_reqs_total[30s])",
          "legendFormat": "error rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(k6_http_reqs_total{status=\"503\"}[30s]) / rate(k6_http_reqs_total[30s])",
          "legendFormat": "503 rate",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 105,
      "title": "Data Transfer",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "binBps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 43 },
      "id": 50,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Data Sent / Received",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_data_sent_total[30s])", "legendFormat": "sent B/s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(k6_data_received_total[30s])", "legendFormat": "received B/s", "refId": "B" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["k6", "load-test", "rtp-ledger"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "K6 Load Tests — RTP Ledger",
  "uid": "k6-rtp-ledger",
  "version": 1
}
